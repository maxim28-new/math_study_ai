# ============================================================
#  小欧 · 多模态一体模式（unified）配置示例
#  一个模型包办文字对话 + 拍照读题，无需单独 OCR 模型
#
#  使用方法：
#    cp .env.unified.example .env
#    # 填入 LLM_API_KEY 后：python3 run.py
# ============================================================

# 多模态一体模式（必填）
LLM_PIPELINE=unified

# 通义千问 qwen3.7-plus（文本+图片+视频多模态，OpenAI 兼容接口）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=

# 模型名请在百炼/千问控制台确认；qwen3.7-plus 支持直接看图教学
LLM_MODEL=qwen3.7-plus

# DeepSeek Thinking 对通义无效，保持默认即可
LLM_THINKING=disabled
LLM_REASONING_EFFORT=high
LLM_SHOW_REASONING=false

# unified 模式下不需要单独的 OCR 模型，以下三项留空
LLM_VISION_BASE_URL=
LLM_VISION_API_KEY=
LLM_VISION_MODEL=

HOST=127.0.0.1
PORT=8000
