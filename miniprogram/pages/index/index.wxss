.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f4f1ea;
}

.banner {
  background: #fbf1dd;
  color: #8a6a20;
  font-size: 24rpx;
  padding: 16rpx 24rpx;
  border-bottom: 1px solid #e7e3da;
}

.modebar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #fff;
  border-bottom: 1px solid #e7e3da;
}
.mode {
  flex: 1;
  text-align: center;
  padding: 14rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  background: #f4f1ea;
  color: #6b6a76;
}
.mode.active {
  background: #eaeeff;
  color: #4f6bed;
  font-weight: 600;
}
.gear {
  width: 64rpx;
  text-align: center;
  font-size: 36rpx;
  color: #6b6a76;
}

.chat {
  flex: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

.msg {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.msg.child { flex-direction: row-reverse; }
.av {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.msg.tutor .av { background: linear-gradient(135deg, #4f6bed, #6f86ff); color: #fff; }
.msg.child .av { background: #e8a13a; color: #fff; }

.bubble {
  max-width: 78%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
}
.msg.tutor .bubble { background: #fff; border: 1px solid #e7e3da; }
.msg.child .bubble { background: #4f6bed; color: #fff; }

.reasoning {
  font-size: 24rpx;
  color: #8a8a96;
  background: #f3f3f3;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  max-height: 200rpx;
  overflow-y: auto;
  white-space: pre-wrap;
}

.cursor { color: #4f6bed; animation: blink 1s step-end infinite; }
@keyframes blink { 50% { opacity: 0; } }

.quick {
  white-space: nowrap;
  padding: 8rpx 16rpx;
  background: #fff;
  border-top: 1px solid #e7e3da;
}
.qbtn {
  display: inline-block;
  margin-right: 12rpx;
  padding: 10rpx 20rpx;
  background: #f4f1ea;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #4f6bed;
}

.preview {
  position: relative;
  margin: 0 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
}
.prev-img { width: 100%; max-height: 200rpx; }
.prev-x {
  position: absolute;
  top: 0;
  right: 8rpx;
  font-size: 40rpx;
  color: #999;
  padding: 8rpx;
}

.composer {
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1px solid #e7e3da;
}
.explore-btn, .cam-btn, .send-btn {
  flex-shrink: 0;
  font-size: 24rpx;
  padding: 0 20rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  border-radius: 12rpx;
}
.explore-btn { background: #4f6bed; color: #fff; }
.cam-btn { background: #eaeeff; color: #4f6bed; min-width: 72rpx; }
.send-btn { background: #4f6bed; color: #fff; }
.input {
  flex: 1;
  min-height: 72rpx;
  max-height: 200rpx;
  padding: 16rpx 20rpx;
  background: #f4f1ea;
  border-radius: 12rpx;
  font-size: 28rpx;
}
