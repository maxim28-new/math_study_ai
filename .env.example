# ============================================================
#  小欧 · 启发式数学老师  —  配置文件模板（split 模式 · 默认）
#  使用方法：复制本文件为 .env ，再把下面的值填上即可。
#     cp .env.example .env
#
#  想用「一个多模态模型包办全部」？见 .env.unified.example
#     cp .env.unified.example .env
# ============================================================

# ── 处理流水线（二选一）──────────────────────────────────────
#   split    OCR 视觉模型读题 + 文字模型教学（默认）
#            适合：文字 DeepSeek + OCR 通义 分开配，教学风格最稳
#   unified  一个多模态模型包办文字+拍照
#            适合：qwen3.7-plus / gpt-4o 等，配置更简单、图形题信息更完整
LLM_PIPELINE=split

# ── 文字模型（split 模式下负责教学 · unified 模式下包办全部 · 必填）──

# 接口地址（兼容 OpenAI 格式即可）。常见选择：
#   DeepSeek（推荐，中文好、便宜）  https://api.deepseek.com/v1
#   OpenAI                          https://api.openai.com/v1
#   月之暗面 Kimi                    https://api.moonshot.cn/v1
#   通义千问                         https://dashscope.aliyuncs.com/compatible-mode/v1
#   本地 Ollama                      http://localhost:11434/v1
LLM_BASE_URL=https://api.deepseek.com/v1

# 文字模型的 API 密钥
LLM_API_KEY=

# 文字模型名（DeepSeek V4 官方模型名，2026-07-24 起旧名 deepseek-chat 将退役）
#   deepseek-v4-flash   快、便宜，推荐日常陪练
#   deepseek-v4-pro     更强，复杂题/奥数可试
LLM_MODEL=deepseek-v4-flash

# DeepSeek V4 Thinking 模式（仅 DeepSeek 生效，其他服务商可忽略）
#   disabled  关闭 thinking，短问短答、响应快（默认，推荐日常陪练）
#   enabled   开启 thinking，模型先深度推理再回复（适合难题/奥数，更慢更贵）
LLM_THINKING=disabled

# thinking 开启时的推理深度：high（默认）或 max
LLM_REASONING_EFFORT=high

# thinking 开启时，是否在界面灰色展示思考过程（true/false，默认 false 不展示）
LLM_SHOW_REASONING=false

# ── 视觉模型（仅 split 模式 · OCR 读题 · 选填）────────────────
# unified 模式下请留空，不需要单独 OCR 模型。

# OCR 接口地址。留空则沿用上面的 LLM_BASE_URL。
# 推荐组合：文字用 DeepSeek，OCR 用通义 qwen-vl-plus，例如：
#   LLM_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_VISION_BASE_URL=

# OCR 密钥。留空则沿用上面的 LLM_API_KEY。
LLM_VISION_API_KEY=

# OCR 模型名。留空则沿用上面的 LLM_MODEL（DeepSeek 不支持看图，拍照功能需单独填此项）。
# 常见视觉模型：qwen-vl-plus / qwen-vl-max / gpt-4o / moonshot-v1-8k-vision-preview / glm-4v
LLM_VISION_MODEL=

# ── 服务监听（一般不用改）────────────────────────────────────

HOST=127.0.0.1
PORT=8000
