# ============================================================
#  小欧 · 启发式数学老师  —  配置文件模板
#  使用方法：复制本文件为 .env ，再把下面的值填上即可。
#     cp .env.example .env
# ============================================================

# ── 文字模型（负责全部教学对话 · 必填）────────────────────────

# 接口地址（兼容 OpenAI 格式即可）。常见选择：
#   DeepSeek（推荐，中文好、便宜）  https://api.deepseek.com/v1
#   OpenAI                          https://api.openai.com/v1
#   月之暗面 Kimi                    https://api.moonshot.cn/v1
#   通义千问                         https://dashscope.aliyuncs.com/compatible-mode/v1
#   本地 Ollama                      http://localhost:11434/v1
LLM_BASE_URL=https://api.deepseek.com/v1

# 文字模型的 API 密钥
LLM_API_KEY=

# 文字模型名（DeepSeek V4 官方模型名，2026-07-24 起旧名 deepseek-chat 将退役）
#   deepseek-v4-flash   快、便宜，推荐日常陪练
#   deepseek-v4-pro     更强，复杂题/奥数可试
LLM_MODEL=deepseek-v4-flash

# ── 视觉模型（只负责拍照 OCR · 选填，可与文字模型用不同服务商）──

# OCR 接口地址。留空则沿用上面的 LLM_BASE_URL。
# 推荐组合：文字用 DeepSeek，OCR 用通义 qwen-vl-plus，例如：
#   LLM_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_VISION_BASE_URL=

# OCR 密钥。留空则沿用上面的 LLM_API_KEY。
LLM_VISION_API_KEY=

# OCR 模型名。留空则沿用上面的 LLM_MODEL（DeepSeek 不支持看图，拍照功能需单独填此项）。
# 常见视觉模型：qwen-vl-plus / qwen-vl-max / gpt-4o / moonshot-v1-8k-vision-preview / glm-4v
LLM_VISION_MODEL=

# ── 服务监听（一般不用改）────────────────────────────────────

HOST=127.0.0.1
PORT=8000
