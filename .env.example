# ============================================================
#  小欧 · 启发式数学老师  —  配置文件模板
#  使用方法：复制本文件为 .env ，再把下面的值填上即可。
#     cp .env.example .env
# ============================================================

# 大模型接口地址（兼容 OpenAI 格式即可）。常见选择：
#   OpenAI        https://api.openai.com/v1
#   DeepSeek      https://api.deepseek.com/v1
#   月之暗面 Kimi  https://api.moonshot.cn/v1
#   通义千问      https://dashscope.aliyuncs.com/compatible-mode/v1
#   本地 Ollama    http://localhost:11434/v1
LLM_BASE_URL=https://api.deepseek.com/v1

# 你的 API 密钥（在对应平台申请）。这是唯一必须填写的项。
LLM_API_KEY=

# 使用的模型名。要和上面的接口地址匹配，例如：
#   OpenAI     gpt-4o-mini / gpt-4o
#   DeepSeek   deepseek-chat
#   Kimi       moonshot-v1-8k
#   通义千问    qwen-plus
LLM_MODEL=deepseek-chat

# （可选）拍照/上传题目时使用的"看得懂图"的视觉模型。
# 留空则沿用上面的 LLM_MODEL。注意：想用拍作业本功能，这个模型必须支持看图，例如：
#   OpenAI     gpt-4o / gpt-4o-mini
#   通义千问    qwen-vl-plus / qwen-vl-max
#   Kimi       moonshot-v1-8k-vision-preview
#   智谱        glm-4v
# 提示：DeepSeek 的 deepseek-chat 不支持看图，如果主力用 DeepSeek，
#       可以把 base_url/密钥换成支持视觉的服务，或单独用一个支持视觉的服务。
LLM_VISION_MODEL=

# 服务监听地址与端口（一般不用改）
HOST=127.0.0.1
PORT=8000
